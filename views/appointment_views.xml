<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="clinical_appointment_view_tree" model="ir.ui.view">
        <field name="name">clinical_appointment.view.tree</field>
        <field name="model">clinical.appointment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="appointment_date" />
                <field name="patient_id" />
                <field name="doctor_id" />
                <field name="state" />
            </tree>
        </field>
    </record>

    <record id="clinical_appointment_view_form" model="ir.ui.view">
        <field name="name">clinical_appointment.view.form</field>
        <field name="model">clinical.appointment</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <header>
                        <field name="state" widget="statusbar" />
                    </header>
                    <group>
                        <field name="patient_id" />
                        <field name="doctor_id" />
                        <field name="appointment_date" />
                        
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" />
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

      <record id="clinical_appointment_action" model="ir.actions.act_window">
        <field name="name">clinical_appointment_action</field>
        <field name="res_model">clinical.appointment</field>
    </record>

        <menuitem
        id="appointments_menu_item"
        name="Appointments"
        parent="clinical_menu"
        action="clinical_appointment_action"
        />

</odoo>
