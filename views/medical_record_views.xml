<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="medical_record_view_tree" model="ir.ui.view">
        <field name="name">medical_record.view.tree</field>
        <field name="model">medical.record</field>
        <field name="arch" type="xml">
            <tree>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="date"/>
                <field name="diagnosis"/>
            </tree>
        </field>
    </record>

    <record id="medical_record_view_form" model="ir.ui.view">
        <field name="name">medical_record.view.form</field>
        <field name="model">medical.record</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <field name="patient_id" />
                        <field name="doctor_id" />
                        <field name="appointment_id" />
                        <field name="diagnosis" />
                        <field name="prescription" />
                        <field name="date" />

                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="medical_record_action" model="ir.actions.act_window">
        <field name="name">medical record</field>
        <field name="res_model">medical.record</field>
    </record>

    <menuitem
        id="medical_record_menu"
        name="medical records"
        sequence="10"
        parent="clinical_menu"
        action="medical_record_action"
        />

</odoo>
