<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="clinical_pharmacy_view_tree" model="ir.ui.view">
        <field name="name">clinical_pharmacy.view.tree</field>
        <field name="model">clinical.pharmacy</field>
        <field name="arch" type="xml">
            <tree>
                <field name="drug_name" />
                <field name="type" />
                <field name="quantity" />
                <field name="price" />
                <field name="barcode" />
                <field name="company_name" />
                <field name="is_imported" />
                <field name="size" />
                <field name="concentration" />
                <field name="active_ingredient" />
            </tree>
        </field>
    </record>

    <record id="clinical_pharmacy_view_form" model="ir.ui.view">
        <field name="name">pharmacy_clinical.view.form</field>
        <field name="model">clinical.pharmacy</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="drug_name" />
                        <field name="type" />
                        <field name="quantity" />
                        <field name="price" />
                        <field name="barcode" />

                    </group>
                    <group>
                     <field name="company_name" />
                    <field name="is_imported" />
                    <field name="size" />
                    <field name="concentration" />
                    <field name="active_ingredient" />

                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="clinical_pharmacy_action" model="ir.actions.act_window">
        <field name="name">Clinical Pharmacy</field>
        <field name="res_model">clinical.pharmacy</field>
    </record>

    <menuitem
        id="clinical_pharmacy_menu"
        name="pharmacy"
        parent="clinical_menu"
        action="clinical_pharmacy_action"
        sequence="10"/>

</odoo>
